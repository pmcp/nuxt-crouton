_archive/**/.data/

# Seed data
seed.sql
apps/velo/seed.sql
apps/velo/seed_reordered.sql

apps/alexdeforce/.data
apps/sintlukas/.data
apps/thinkgraph/.data

# Wrangler local state
apps/*/.wrangler/state/
apps/*/.wrangler/deploy/

# Screenshots (temp)
*.png
# Demo recordings (shot-scraper video — see .claude/skills/demo-video)
*.webm
*.mp4
# …except committed ticket-diagram renders (the ticket-diagram skill embeds these in epic/PR bodies)
!writeups/diagrams/*.png
# …and committed ui-proposal --static mockup renders (embedded inline in the draft-PR sticky; #613)
!writeups/ui-proposals/*.png

# Playwright saved auth state (generated by e2e/auth.setup.ts)
e2e/.auth/*
!e2e/.auth/.gitkeep

# Playwright run artifacts
playwright-report/
test-results/

# Claude Code projects
.claude/projects/
.claude/.package-edit-approved
# task-decompose worker worktrees (agent scratch — never committed)
.claude/worktrees/
apps/kvr/.data
apps/fanfare/.data
apps/three-demo/.data
fixtures/minimal/.data
fixtures/with-pages/.data
fixtures/with-bookings/.data
fixtures/with-assets/.data
fixtures/with-collab/.data
# Loose Excalidraw scenes — the editable scene is embedded in the committed PNG instead
writeups/diagrams/*.excalidraw

# Red-team scan reports — security findings kept OUT of git (public repo).
# The daily/skill flows surface findings via a private disclosure channel, not
# committed files. See epic #540 / the public-repo disclosure note on PR #548.
writeups/reports/red-team-*.md
!writeups/reports/red-team-TEMPLATE.md

pocs/crouton-builder-demo/.data
# Loop Station invocation traces (WS2, #929) — runtime exhaust, NOT committed.
# Reconstructed from session transcripts (names + ids + durations only, no tool
# payloads); shipped from CI as artifacts and aggregated for the WS3 view. The
# committed Loop Station dataset is only writeups/loop-station/history.jsonl (WS1).
trace.jsonl
loop-station-trace*.jsonl
writeups/loop-station/traces/

retired/pocs/blog/.data
pocs/crouton-builder/.data
pocs/booking-demo/.data
