{
  "name": {
    "type": "string",
    "meta": { "required": true, "label": "Product Name", "maxLength": 200, "area": "main" }
  },
  "description": {
    "type": "text",
    "meta": { "label": "Description", "area": "main" }
  },
  "shortDescription": {
    "type": "text",
    "meta": { "label": "Short Description", "area": "main" }
  },
  "price": {
    "type": "decimal",
    "meta": { "required": true, "label": "Price", "area": "sidebar" }
  },
  "stock": {
    "type": "number",
    "meta": { "label": "Stock", "default": 0, "area": "sidebar" }
  },
  "featured": {
    "type": "boolean",
    "meta": { "label": "Featured", "default": false, "area": "sidebar" }
  },
  "inStock": {
    "type": "boolean",
    "meta": { "label": "In Stock", "default": true, "area": "sidebar" }
  },
  "thumbnail": {
    "type": "image",
    "meta": { "label": "Thumbnail", "area": "sidebar" }
  },
  "tags": {
    "type": "array",
    "meta": { "label": "Tags", "area": "sidebar" }
  }
}
