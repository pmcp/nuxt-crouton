# ThinkGraph Worker Configuration

# ThinkGraph server URL (your Cloudflare Pages deployment)
THINKGRAPH_URL=https://thinkgraph.example.com

# Team slug or ID to watch
THINKGRAPH_TEAM=my-team

# Auth: user credentials for initial token exchange
# The worker authenticates once via /api/teams/:id/worker-auth to get a service token
THINKGRAPH_EMAIL=worker@example.com
THINKGRAPH_PASSWORD=

# Or use a pre-generated service token directly
THINKGRAPH_SERVICE_TOKEN=

# Pi Agent / LLM configuration
ANTHROPIC_API_KEY=
PI_MODEL=claude-sonnet-4-20250514

# Working directory for agent sessions (where git repos live)
PI_WORK_DIR=/home/pi/repos

# Max concurrent agent sessions (default: 3)
PI_MAX_SESSIONS=3

# Session persistence directory
PI_SESSION_DIR=/home/pi/thinkgraph-sessions
