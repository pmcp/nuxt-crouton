{
  "name": "agenda",
  "label": "Agenda",
  "icon": "i-lucide-calendar",
  "description": "Events and performances",
  "fields": [
    {
      "name": "title",
      "type": "string",
      "label": "Title",
      "required": true,
      "maxLength": 300,
      "area": "main"
    },
    {
      "name": "date",
      "type": "date",
      "label": "Date",
      "required": true,
      "area": "sidebar"
    },
    {
      "name": "content",
      "type": "text",
      "label": "Details",
      "area": "main",
      "component": "CroutonPagesEditorBlockEditor",
      "description": "Location, description, links"
    },
    {
      "name": "thumbnail",
      "type": "string",
      "label": "Thumbnail URL",
      "maxLength": 500,
      "area": "sidebar"
    },
    {
      "name": "status",
      "type": "string",
      "label": "Status",
      "required": true,
      "default": "draft",
      "maxLength": 20,
      "area": "sidebar",
      "displayAs": "optionsSelect",
      "options": [
        { "value": "draft", "label": "Draft" },
        { "value": "published", "label": "Published" },
        { "value": "archived", "label": "Archived" }
      ]
    },
    {
      "name": "publishedAt",
      "type": "date",
      "label": "Published At",
      "area": "sidebar",
      "picker": true
    }
  ]
}
