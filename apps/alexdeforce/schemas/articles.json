{
  "name": "articles",
  "label": "Articles",
  "icon": "i-lucide-file-text",
  "description": "Poetry, text, images, radio shows, and news",
  "fields": [
    {
      "name": "title",
      "type": "string",
      "label": "Title",
      "required": true,
      "maxLength": 300,
      "area": "main"
    },
    {
      "name": "date",
      "type": "date",
      "label": "Date",
      "required": true,
      "area": "sidebar"
    },
    {
      "name": "category",
      "type": "string",
      "label": "Category",
      "required": true,
      "area": "sidebar",
      "refTarget": "categories"
    },
    {
      "name": "content",
      "type": "text",
      "label": "Content",
      "area": "main",
      "component": "CroutonPagesEditorBlockEditor",
      "description": "Article body with embed blocks (TipTap JSON)"
    },
    {
      "name": "imageUrl",
      "type": "string",
      "label": "Image URL",
      "maxLength": 500,
      "area": "sidebar",
      "description": "External image URL or R2 pathname"
    },
    {
      "name": "tags",
      "type": "array",
      "label": "Tags",
      "area": "sidebar",
      "refTarget": "tags"
    },
    {
      "name": "featured",
      "type": "boolean",
      "label": "Featured",
      "default": false,
      "area": "sidebar"
    },
    {
      "name": "status",
      "type": "string",
      "label": "Status",
      "required": true,
      "default": "draft",
      "maxLength": 20,
      "area": "sidebar",
      "displayAs": "optionsSelect",
      "options": [
        { "value": "draft", "label": "Draft" },
        { "value": "published", "label": "Published" },
        { "value": "archived", "label": "Archived" }
      ]
    },
    {
      "name": "publishedAt",
      "type": "date",
      "label": "Published At",
      "area": "sidebar",
      "picker": true
    }
  ]
}
