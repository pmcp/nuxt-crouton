{
  "display": {
    "title": "name",
    "subtitle": "category",
    "image": "image",
    "badge": "status",
    "description": "description"
  },
  "fields": {
    "name": {
      "type": "string",
      "meta": {
        "required": true,
        "label": "Service Name",
        "area": "main"
      }
    },
    "description": {
      "type": "text",
      "meta": {
        "label": "Description",
        "area": "main"
      }
    },
    "category": {
      "type": "string",
      "meta": {
        "required": true,
        "label": "Category",
        "area": "main",
        "options": [
          "consultation",
          "treatment",
          "maintenance",
          "package",
          "workshop"
        ]
      }
    },
    "duration": {
      "type": "integer",
      "meta": {
        "required": true,
        "label": "Duration (minutes)",
        "area": "main"
      }
    },
    "price": {
      "type": "decimal",
      "meta": {
        "required": true,
        "label": "Base Price",
        "area": "main"
      }
    },
    "image": {
      "type": "image",
      "meta": {
        "label": "Service Image",
        "area": "sidebar"
      }
    },
    "requirements": {
      "type": "array",
      "meta": {
        "label": "Requirements",
        "area": "sidebar"
      }
    },
    "maxParticipants": {
      "type": "integer",
      "meta": {
        "label": "Max Participants",
        "area": "sidebar",
        "default": 1
      }
    },
    "status": {
      "type": "string",
      "meta": {
        "label": "Status",
        "area": "meta",
        "default": "active",
        "displayAs": "badge",
        "options": [
          "active",
          "inactive",
          "seasonal"
        ]
      }
    },
    "bookingCount": {
      "type": "integer",
      "meta": {
        "label": "Total Bookings",
        "area": "meta",
        "default": 0,
        "readOnly": true
      }
    }
  }
}