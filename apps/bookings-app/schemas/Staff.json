{
  "display": {
    "title": "name",
    "subtitle": "role",
    "image": "avatar",
    "badge": "status",
    "description": "bio"
  },
  "fields": {
    "name": {
      "type": "string",
      "meta": {
        "required": true,
        "label": "Full Name",
        "area": "main"
      }
    },
    "email": {
      "type": "string",
      "meta": {
        "required": true,
        "unique": true,
        "label": "Email Address",
        "area": "main"
      }
    },
    "role": {
      "type": "string",
      "meta": {
        "required": true,
        "label": "Role",
        "area": "main",
        "options": [
          "manager",
          "practitioner",
          "assistant",
          "receptionist"
        ]
      }
    },
    "specialties": {
      "type": "array",
      "meta": {
        "label": "Specialties",
        "area": "main"
      }
    },
    "avatar": {
      "type": "image",
      "meta": {
        "label": "Profile Photo",
        "area": "sidebar"
      }
    },
    "bio": {
      "type": "text",
      "meta": {
        "label": "Biography",
        "area": "sidebar"
      }
    },
    "phone": {
      "type": "string",
      "meta": {
        "label": "Phone Number",
        "area": "sidebar"
      }
    },
    "workingHours": {
      "type": "json",
      "meta": {
        "label": "Working Hours",
        "area": "sidebar"
      }
    },
    "hourlyRate": {
      "type": "decimal",
      "meta": {
        "label": "Hourly Rate",
        "area": "meta"
      }
    },
    "status": {
      "type": "string",
      "meta": {
        "label": "Status",
        "area": "meta",
        "default": "active",
        "displayAs": "badge",
        "options": [
          "active",
          "inactive",
          "on-leave",
          "part-time"
        ]
      }
    }
  }
}