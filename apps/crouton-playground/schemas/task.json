{
  "title": {
    "type": "string",
    "meta": { "required": true, "label": "Task Title", "area": "main" }
  },
  "description": {
    "type": "text",
    "meta": { "label": "Description", "area": "main" }
  },
  "status": {
    "type": "string",
    "meta": {
      "label": "Status",
      "default": "todo",
      "area": "sidebar",
      "options": ["todo", "in-progress", "done", "blocked"]
    }
  },
  "dueDate": {
    "type": "date",
    "meta": { "label": "Due Date", "area": "sidebar" }
  },
  "completed": {
    "type": "boolean",
    "meta": { "label": "Completed", "default": false, "area": "sidebar" }
  },
  "priority": {
    "type": "number",
    "meta": { "label": "Priority (1-5)", "default": 3, "area": "sidebar" }
  },
  "assigneeId": {
    "type": "string",
    "refTarget": "contacts",
    "meta": { "label": "Assignee", "area": "sidebar" }
  },
  "subtasks": {
    "type": "repeater",
    "meta": {
      "label": "Subtasks",
      "addLabel": "Add Subtask",
      "sortable": true,
      "area": "main",
      "properties": {
        "title": { "type": "string", "required": true, "label": "Subtask Title" },
        "done": { "type": "boolean", "label": "Done" }
      }
    }
  }
}
