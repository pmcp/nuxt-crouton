{
  "repo": {
    "type": "string",
    "meta": {
      "required": true,
      "label": "Repository",
      "description": "GitHub repo in owner/name format",
      "area": "main"
    }
  },
  "branch": {
    "type": "string",
    "meta": {
      "label": "Branch",
      "default": "main",
      "description": "Branch to watch",
      "area": "sidebar"
    }
  },
  "lastCheckedSha": {
    "type": "string",
    "meta": {
      "label": "Last Checked SHA",
      "description": "Most recent commit SHA seen by the watcher",
      "area": "sidebar"
    }
  },
  "notes": {
    "type": "text",
    "meta": {
      "label": "Notes",
      "description": "Why this repo is being watched",
      "area": "main"
    }
  },
  "active": {
    "type": "boolean",
    "meta": {
      "label": "Active",
      "default": true,
      "description": "Whether the watcher should poll this repo",
      "area": "sidebar"
    }
  }
}
