{
  "projectId": {
    "type": "string",
    "refTarget": "projects",
    "meta": {
      "required": true,
      "label": "Project",
      "area": "sidebar",
      "group": "structure"
    }
  },
  "parentId": {
    "type": "string",
    "refTarget": "nodes",
    "meta": {
      "label": "Parent Node",
      "description": "Parent node for tree structure",
      "area": "sidebar",
      "group": "structure"
    }
  },
  "template": {
    "type": "string",
    "meta": {
      "label": "Template",
      "default": "idea",
      "description": "idea | research | task | feature | meta",
      "area": "sidebar",
      "group": "classification",
      "displayAs": "badge"
    }
  },
  "steps": {
    "type": "json",
    "meta": {
      "label": "Steps",
      "description": "Configurable pipeline step sequence (JSON array of step names)",
      "area": "sidebar",
      "group": "pipeline"
    }
  },
  "title": {
    "type": "string",
    "meta": {
      "required": true,
      "label": "Title",
      "description": "Node title",
      "area": "main"
    }
  },
  "summary": {
    "type": "string",
    "meta": {
      "label": "Summary",
      "description": "AI-generated one-liner (~50 tokens) for context assembly",
      "area": "main"
    }
  },
  "brief": {
    "type": "text",
    "meta": {
      "label": "Brief",
      "description": "Input: what needs to happen",
      "area": "main"
    }
  },
  "output": {
    "type": "text",
    "meta": {
      "label": "Output",
      "description": "Result: what was produced",
      "area": "main"
    }
  },
  "status": {
    "type": "string",
    "meta": {
      "required": true,
      "default": "idle",
      "label": "Status",
      "description": "idle | draft | queued | active | working | waiting | blocked | done | error",
      "area": "sidebar",
      "group": "classification",
      "displayAs": "badge"
    }
  },
  "assignee": {
    "type": "string",
    "meta": {
      "label": "Assignee",
      "default": "human",
      "description": "pi | human | client",
      "area": "sidebar",
      "group": "routing",
      "displayAs": "badge"
    }
  },
  "provider": {
    "type": "string",
    "meta": {
      "label": "Provider",
      "description": "claude-code | codex | flux | openai | anthropic",
      "area": "sidebar",
      "group": "routing"
    }
  },
  "stage": {
    "type": "string",
    "meta": {
      "label": "Stage",
      "description": "Current pipeline step being executed",
      "area": "sidebar",
      "group": "pipeline",
      "displayAs": "badge"
    }
  },
  "signal": {
    "type": "string",
    "meta": {
      "label": "Signal",
      "description": "green | orange | red",
      "area": "sidebar",
      "group": "pipeline",
      "displayAs": "badge"
    }
  },
  "starred": {
    "type": "boolean",
    "meta": {
      "default": false,
      "label": "Starred",
      "description": "Marked as important — always included in context",
      "area": "sidebar",
      "group": "classification"
    }
  },
  "pinned": {
    "type": "boolean",
    "meta": {
      "default": false,
      "label": "Pinned",
      "description": "Always include full content in AI context",
      "area": "sidebar",
      "group": "classification"
    }
  },
  "origin": {
    "type": "string",
    "meta": {
      "label": "Origin",
      "default": "human",
      "description": "human | ai | mcp | notion",
      "area": "sidebar",
      "group": "provenance",
      "displayAs": "badge"
    }
  },
  "contextScope": {
    "type": "string",
    "meta": {
      "label": "Context Scope",
      "default": "branch",
      "description": "full | branch | manual",
      "area": "sidebar",
      "group": "context"
    }
  },
  "worktree": {
    "type": "string",
    "meta": {
      "label": "Worktree",
      "description": "Git worktree branch for this node's work",
      "area": "sidebar",
      "group": "execution"
    }
  },
  "deployUrl": {
    "type": "string",
    "meta": {
      "label": "Preview URL",
      "description": "Deployed preview for this work",
      "area": "sidebar",
      "group": "execution"
    }
  },
  "skill": {
    "type": "string",
    "meta": {
      "label": "Skill",
      "description": "Which crouton skill to run",
      "area": "sidebar",
      "group": "routing"
    }
  },
  "sessionId": {
    "type": "string",
    "meta": {
      "label": "Session ID",
      "description": "External session/job ID",
      "area": "sidebar",
      "group": "execution"
    }
  },
  "retrospective": {
    "type": "text",
    "meta": {
      "label": "Retrospective",
      "description": "Agent reflection on this session",
      "area": "main",
      "group": "output"
    }
  },
  "artifacts": {
    "type": "json",
    "meta": {
      "label": "Artifacts",
      "description": "References to outputs — PR URLs, deploy URLs, screenshots, generated files",
      "area": "sidebar",
      "group": "output"
    }
  }
}
