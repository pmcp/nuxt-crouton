# Authentication (required)
BETTER_AUTH_SECRET=your-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email (optional - required for booking email notifications)
# RESEND_API_KEY=re_xxx                    # Local dev (read at build time)
# NUXT_EMAIL_RESEND_API_KEY=re_xxx         # Cloudflare (read at runtime)
# NUXT_EMAIL_FROM=noreply@yourdomain.com
# NUXT_EMAIL_FROM_NAME=MyApp

# Maps (optional - MapLibre + OpenFreeMap + Nominatim, no API key required)
# MAPS_STYLE=https://tiles.openfreemap.org/styles/positron   # override default style
# NUXT_PUBLIC_MAPS_STYLE=https://tiles.openfreemap.org/styles/positron  # Cloudflare (runtime)
# NOMINATIM_URL=https://nominatim.example.com                # self-hosted geocoder
# NUXT_MAPS_GEOCODING_URL=https://nominatim.example.com      # Cloudflare (runtime)

# AI (optional)
# NUXT_ANTHROPIC_API_KEY=
