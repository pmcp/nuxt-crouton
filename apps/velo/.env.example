# Authentication (required)
BETTER_AUTH_SECRET=your-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email (optional - required for booking email notifications)
# RESEND_API_KEY=re_xxx                    # Local dev (read at build time)
# NUXT_EMAIL_RESEND_API_KEY=re_xxx         # Cloudflare (read at runtime)
# NUXT_EMAIL_FROM=noreply@yourdomain.com
# NUXT_EMAIL_FROM_NAME=MyApp

# Maps (optional - Mapbox integration)
# MAPBOX_TOKEN=sk.eyJ...                   # Local dev (read at build time)
# NUXT_MAPBOX_ACCESS_TOKEN=sk.eyJ...       # Cloudflare (read at runtime, server-only)
# MAPBOX_PUBLIC_TOKEN=pk.eyJ...            # Local dev (read at build time)
# NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ...# Cloudflare (read at runtime, client-side)

# AI (optional)
# NUXT_ANTHROPIC_API_KEY=
