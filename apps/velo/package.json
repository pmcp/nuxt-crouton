{
  "name": "velo",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare 2>/dev/null || true",
    "typecheck": "nuxt typecheck",
    "cf:deploy": "NITRO_PRESET=cloudflare-pages nuxt build && npx wrangler pages deploy dist",
    "cf:preview": "NITRO_PRESET=cloudflare-pages CLOUDFLARE_ENV=preview nuxt build && npx wrangler pages deploy dist --branch preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx wrangler d1 migrations apply velo-db --local",
    "db:migrate:prod": "npx wrangler d1 migrations apply velo-db --remote"
  },
  "dependencies": {
    "@fyit/crouton": "workspace:*",
    "@fyit/crouton-core": "workspace:*",
    "@fyit/crouton-i18n": "workspace:*",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "nuxt": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "@fyit/crouton-assets": "workspace:*",
    "@fyit/crouton-bookings": "workspace:*",
    "@fyit/crouton-email": "workspace:*",
    "@fyit/crouton-pages": "workspace:*"
  },
  "devDependencies": {
    "@fyit/crouton-cli": "workspace:*",
    "drizzle-kit": "catalog:",
    "wrangler": "catalog:"
  }
}
