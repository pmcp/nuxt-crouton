# Auth (32+ chars)
BETTER_AUTH_SECRET=local-dev-secret-32-chars-minimum-change-me
BETTER_AUTH_URL=http://localhost:3011

# Resend (required for email-on-submit)
NUXT_EMAIL_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
NUXT_EMAIL_FROM_ADDRESS=no-reply@kvr.example.com

# Public form — shared link: /kvr/submit?t=<NUXT_KVR_PUBLIC_TOKEN>
NUXT_KVR_PUBLIC_TOKEN=generate-with-openssl-rand-base64-24
# Optional: hardcode where public submissions go. If empty, falls back to kvr-settings default recipient.
NUXT_KVR_PUBLIC_RECIPIENT=
NUXT_KVR_PUBLIC_TEAM_SLUG=kvr
