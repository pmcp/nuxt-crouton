{
  "name": "fanfare",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare 2>/dev/null || true",
    "typecheck": "nuxt typecheck",
    "cf:deploy": "NITRO_PRESET=cloudflare-pages nuxt build && npx wrangler pages deploy dist",
    "cf:preview": "NITRO_PRESET=cloudflare-pages CLOUDFLARE_ENV=preview nuxt build && npx wrangler pages deploy dist --branch preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx wrangler d1 migrations apply fanfare-db --local",
    "db:migrate:prod": "npx wrangler d1 migrations apply fanfare-db --remote",
    "db:seed": "pnpm db:seed:local",
    "db:seed:local": "crouton-seed --db fanfare-db",
    "db:seed:remote": "crouton-seed --db fanfare-db --remote"
  },
  "dependencies": {
    "@fyit/crouton": "workspace:*",
    "@fyit/crouton-charts": "workspace:*",
    "@fyit/crouton-core": "workspace:*",
    "@fyit/crouton-i18n": "workspace:*",
    "@fyit/crouton-pages": "workspace:*",
    "@fyit/crouton-sales": "workspace:*",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "node-thermal-printer": "^4.6.0",
    "nuxt": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@fyit/crouton-cli": "workspace:*",
    "drizzle-kit": "catalog:",
    "wrangler": "catalog:"
  }
}
