{
  "display": {
    "title": "name",
    "subtitle": "description",
    "image": "icon",
    "badge": "status"
  },
  "fields": {
    "status": {
      "type": "string",
      "meta": {
        "required": true,
        "label": "Status",
        "area": "sidebar",
        "default": "Active",
        "displayAs": "badge",
        "options": [
          "Active",
          "Inactive"
        ]
      }
    },
    "name": {
      "type": "string",
      "meta": {
        "required": true,
        "label": "Room Type Name",
        "area": "main"
      }
    },
    "description": {
      "type": "text",
      "meta": {
        "label": "Description",
        "area": "main"
      }
    },
    "icon": {
      "type": "image",
      "meta": {
        "label": "Icon",
        "area": "sidebar"
      }
    },
    "capacity": {
      "type": "integer",
      "meta": {
        "required": true,
        "label": "Default Capacity",
        "area": "main"
      }
    },
    "hourlyRate": {
      "type": "decimal",
      "meta": {
        "label": "Hourly Rate",
        "area": "main"
      }
    },
    "advanceBookingDays": {
      "type": "integer",
      "meta": {
        "required": true,
        "label": "Max Advance Booking (Days)",
        "area": "sidebar",
        "default": 30
      }
    },
    "maxBookingHours": {
      "type": "integer",
      "meta": {
        "required": true,
        "label": "Max Booking Duration (Hours)",
        "area": "sidebar",
        "default": 4
      }
    },
    "requiresApproval": {
      "type": "boolean",
      "meta": {
        "label": "Requires Approval",
        "area": "sidebar",
        "default": false
      }
    },
    "allowedMembershipTypes": {
      "type": "array",
      "meta": {
        "label": "Allowed Membership Types",
        "area": "sidebar"
      }
    }
  }
}