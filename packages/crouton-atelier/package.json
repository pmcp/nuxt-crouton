{
  "name": "@fyit/crouton-atelier",
  "version": "0.1.0",
  "description": "Visual app builder for Nuxt Crouton — compose apps from pre-defined blocks",
  "type": "module",
  "exports": {
    ".": "./nuxt.config.ts",
    "./server/database/schema": "./server/database/schema.ts"
  },
  "main": "./nuxt.config.ts",
  "files": [
    "app",
    "server",
    "nuxt.config.ts"
  ],
  "scripts": {
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxi prepare",
    "typecheck": "nuxt typecheck"
  },
  "devDependencies": {
    "@nuxt/kit": "^3.14.0",
    "@nuxt/schema": "^3.14.0",
    "@nuxthub/core": "^0.8.0",
    "nuxt": "^4.3.1",
    "typescript": "^5.7.0",
    "vue": "^3.5.25"
  },
  "peerDependencies": {
    "@fyit/crouton-core": "workspace:*",
    "@fyit/crouton-collab": "workspace:*",
    "@nuxt/ui": "^4.0.0",
    "@nuxthub/core": ">=0.8.0",
    "nuxt": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/ui": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmcp/nuxt-crouton.git",
    "directory": "packages/crouton-atelier"
  },
  "keywords": [
    "nuxt",
    "nuxt-layer",
    "app-builder",
    "visual-builder",
    "crouton",
    "blocks"
  ],
  "author": "FYIT",
  "license": "MIT"
}
