{
  "name": "@fyit/crouton-analytics",
  "version": "0.1.0",
  "description": "Provider-agnostic usage analytics for nuxt-crouton — PostHog default, swappable backend, lean-loop events",
  "type": "module",
  "main": "./nuxt.config.ts",
  "exports": {
    ".": "./nuxt.config.ts"
  },
  "files": [
    "app",
    "types",
    "nuxt.config.ts",
    "crouton.manifest.ts"
  ],
  "scripts": {
    "typecheck": "npx nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nuxt/scripts": "^1.2.1"
  },
  "peerDependencies": {
    "@fyit/crouton-core": "workspace:*",
    "nuxt": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "nuxt",
    "nuxt-layer",
    "analytics",
    "posthog",
    "crouton"
  ],
  "author": "FYIT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FriendlyInternet/nuxt-crouton.git",
    "directory": "packages/crouton-analytics"
  },
  "bugs": {
    "url": "https://github.com/FriendlyInternet/nuxt-crouton/issues"
  },
  "homepage": "https://github.com/FriendlyInternet/nuxt-crouton#readme",
  "publishConfig": {
    "access": "public"
  }
}
