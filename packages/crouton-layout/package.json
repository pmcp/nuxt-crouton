{
  "name": "@fyit/crouton-layout",
  "version": "0.1.0",
  "description": "Deterministic layout engine for Nuxt Crouton — the layout editor, renderer, default-layout compose pass, placeable blocks, and layout_configs storage. Default-on via @fyit/crouton.",
  "type": "module",
  "main": "./nuxt.config.ts",
  "exports": {
    ".": "./nuxt.config.ts",
    "./app/utils/layout-compose": "./app/utils/layout-compose.ts",
    "./app/utils/layout-viability": "./app/utils/layout-viability.ts",
    "./app/utils/layout-edit": "./app/utils/layout-edit.ts",
    "./app/utils/layout-compose-bridge": "./app/utils/layout-compose-bridge.ts",
    "./app/utils/layout-snap": "./app/utils/layout-snap.ts",
    "./app/composables/useCroutonComposeGestures": "./app/composables/useCroutonComposeGestures.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "app",
    "server",
    "crouton.manifest.ts",
    "nuxt.config.ts",
    "README.md"
  ],
  "keywords": [
    "nuxt",
    "nuxt-layer",
    "layout",
    "crouton"
  ],
  "author": "FYIT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FriendlyInternet/nuxt-crouton.git",
    "directory": "packages/crouton-layout"
  },
  "bugs": {
    "url": "https://github.com/FriendlyInternet/nuxt-crouton/issues"
  },
  "homepage": "https://github.com/FriendlyInternet/nuxt-crouton#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@fyit/crouton-auth": "workspace:*",
    "@fyit/crouton-core": "workspace:*",
    "@nuxt/ui": "^4.3.0",
    "nuxt": "^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^16.6.0",
    "vitest": "^2.1.0"
  }
}
