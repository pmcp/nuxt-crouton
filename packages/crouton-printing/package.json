{
  "name": "@fyit/crouton-printing",
  "version": "0.1.0",
  "description": "Domain-agnostic printing layer for Nuxt Crouton - print-job queue, ESC/POS engine, drivers, and on-site transport. Consumed by crouton-sales, crouton-bookings, etc.",
  "type": "module",
  "main": "./nuxt.config.ts",
  "files": [
    "app",
    "server",
    "schemas",
    "dist",
    "nuxt.config.ts",
    "README.md"
  ],
  "exports": {
    ".": "./nuxt.config.ts",
    "./server/database/schema": {
      "import": "./server/database/schema.ts",
      "types": "./server/database/schema.ts"
    },
    "./server/utils/print-job-queue": {
      "import": "./server/utils/print-job-queue.ts",
      "types": "./server/utils/print-job-queue.ts"
    },
    "./server/utils/print-job-status": {
      "import": "./server/utils/print-job-status.ts",
      "types": "./server/utils/print-job-status.ts"
    },
    "./server/utils/receipt-formatter": {
      "import": "./server/utils/receipt-formatter.ts",
      "types": "./server/utils/receipt-formatter.ts"
    },
    "./server/utils/print-queue-service": {
      "import": "./server/utils/print-queue-service.ts",
      "types": "./server/utils/print-queue-service.ts"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "keywords": [
    "nuxt",
    "nuxt-layer",
    "crouton",
    "printing",
    "thermal-printing",
    "escpos",
    "receipt"
  ],
  "author": "FYIT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FriendlyInternet/nuxt-crouton.git",
    "directory": "packages/crouton-printing"
  },
  "bugs": {
    "url": "https://github.com/FriendlyInternet/nuxt-crouton/issues"
  },
  "homepage": "https://github.com/FriendlyInternet/nuxt-crouton#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0",
    "@fyit/crouton-core": "workspace:*"
  },
  "dependencies": {
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "unbuild": "^3.6.1",
    "vitest": "^4.0.0"
  }
}
