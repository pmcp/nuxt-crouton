{
  "title": {
    "type": "string",
    "meta": {
      "required": true,
      "maxLength": 200,
      "label": "Title",
      "area": "main"
    }
  },
  "slug": {
    "type": "string",
    "meta": {
      "required": true,
      "unique": true,
      "maxLength": 200,
      "label": "Slug",
      "area": "main",
      "help": "URL-friendly identifier used as the post's URL segment (e.g. \"my-first-post\")"
    }
  },
  "body": {
    "type": "text",
    "meta": {
      "label": "Body",
      "area": "main",
      "component": "CroutonEditorSimple",
      "help": "Rich text body of the post"
    }
  },
  "author": {
    "type": "string",
    "meta": {
      "maxLength": 200,
      "label": "Author",
      "area": "sidebar"
    }
  },
  "publishedAt": {
    "type": "datetime",
    "meta": {
      "label": "Published At",
      "area": "sidebar"
    }
  },
  "status": {
    "type": "string",
    "meta": {
      "required": true,
      "default": "draft",
      "label": "Status",
      "area": "sidebar",
      "options": ["draft", "published"],
      "displayAs": "optionsSelect"
    }
  },
  "tags": {
    "type": "array",
    "meta": {
      "label": "Tags",
      "area": "sidebar",
      "help": "List of tags for the post"
    }
  }
}
