{
  "name": "assets",
  "label": "Assets",
  "icon": "i-lucide-image",
  "description": "Media library: images, videos, audio, and documents",
  "layer": "crouton",
  "fields": [
    {
      "name": "userId",
      "type": "string",
      "label": "Uploaded By",
      "required": true,
      "area": "meta"
    },
    {
      "name": "filename",
      "type": "string",
      "label": "Filename",
      "required": true,
      "area": "main"
    },
    {
      "name": "pathname",
      "type": "string",
      "label": "File Path",
      "required": true,
      "area": "main"
    },
    {
      "name": "contentType",
      "type": "string",
      "label": "MIME Type",
      "area": "sidebar"
    },
    {
      "name": "size",
      "type": "number",
      "label": "File Size (bytes)",
      "area": "sidebar"
    },
    {
      "name": "category",
      "type": "string",
      "label": "Category",
      "area": "sidebar",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" },
        { "value": "audio", "label": "Audio" },
        { "value": "document", "label": "Document" },
        { "value": "other", "label": "Other" }
      ]
    },
    {
      "name": "width",
      "type": "number",
      "label": "Width (px)",
      "area": "sidebar"
    },
    {
      "name": "height",
      "type": "number",
      "label": "Height (px)",
      "area": "sidebar"
    },
    {
      "name": "alt",
      "type": "string",
      "label": "Alt Text (for accessibility & SEO)",
      "area": "main",
      "translatable": true
    },
    {
      "name": "uploadedAt",
      "type": "date",
      "label": "Uploaded At",
      "area": "meta"
    },
    {
      "name": "updatedBy",
      "type": "string",
      "label": "Updated By",
      "area": "meta"
    }
  ]
}
