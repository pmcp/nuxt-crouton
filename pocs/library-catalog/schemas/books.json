{
  "title": {
    "type": "string",
    "meta": {
      "required": true,
      "maxLength": 300,
      "label": "Title",
      "area": "main"
    }
  },
  "isbn": {
    "type": "string",
    "meta": {
      "unique": true,
      "maxLength": 20,
      "label": "ISBN",
      "area": "sidebar"
    }
  },
  "publishedYear": {
    "type": "number",
    "meta": {
      "label": "Published Year",
      "area": "sidebar"
    }
  },
  "coverImage": {
    "type": "image",
    "meta": {
      "label": "Cover Image",
      "area": "sidebar"
    }
  },
  "description": {
    "type": "text",
    "meta": {
      "label": "Description",
      "area": "main",
      "component": "EditorSimple"
    }
  },
  "authorId": {
    "type": "string",
    "refTarget": "authors",
    "meta": {
      "required": true,
      "label": "Author",
      "area": "sidebar"
    }
  },
  "genreId": {
    "type": "string",
    "refTarget": "genres",
    "meta": {
      "label": "Genre",
      "area": "sidebar"
    }
  },
  "copiesTotal": {
    "type": "number",
    "meta": {
      "label": "Total Copies",
      "area": "sidebar",
      "default": 1
    }
  },
  "copiesAvailable": {
    "type": "number",
    "meta": {
      "label": "Available Copies",
      "area": "sidebar",
      "default": 1
    }
  }
}
