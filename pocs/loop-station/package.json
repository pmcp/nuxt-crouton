{
  "name": "loop-station",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/prepare-data.mjs && nuxt dev",
    "build": "node scripts/prepare-data.mjs && nuxt build",
    "generate": "node scripts/prepare-data.mjs && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare 2>/dev/null || true",
    "typecheck": "nuxt typecheck",
    "cf:staging": "node scripts/prepare-data.mjs && NITRO_PRESET=cloudflare_module nuxt build && npx wrangler deploy --env staging"
  },
  "dependencies": {
    "@fyit/crouton-themes": "workspace:*",
    "@nuxt/ui": "catalog:",
    "nuxt-charts": "^2.1.2",
    "@vue-flow/core": "^1.41.2",
    "@vue-flow/background": "^1.3.0",
    "@vue-flow/controls": "^1.1.2",
    "@dagrejs/dagre": "^1.1.4",
    "nuxt": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "wrangler": "catalog:"
  }
}
