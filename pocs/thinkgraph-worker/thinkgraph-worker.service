[Unit]
Description=ThinkGraph Pi Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pmcp
WorkingDirectory=/home/FriendlyInternet/nuxt-crouton/apps/thinkgraph-worker
ExecStart=/home/pmcp/.nvm/versions/node/v22.22.1/bin/node dist/index.js
Restart=always
RestartSec=10
EnvironmentFile=/home/FriendlyInternet/nuxt-crouton/apps/thinkgraph-worker/.env

[Install]
WantedBy=multi-user.target
