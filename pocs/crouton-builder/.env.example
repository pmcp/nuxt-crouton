# Authentication (required by crouton-core)
BETTER_AUTH_SECRET=your-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3011

# Round-trip posting (#974) — optional. Absent → the endpoint returns the comment
# body to paste by hand instead of posting.
# NUXT_GITHUB_TOKEN=
# NUXT_PUBLIC_BUILDER_REPO=FriendlyInternet/nuxt-crouton
