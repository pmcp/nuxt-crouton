{
  "name": "kvr",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare 2>/dev/null || true",
    "typecheck": "nuxt typecheck",
    "cf:deploy": "NITRO_PRESET=cloudflare-pages nuxt build && npx wrangler pages deploy dist",
    "cf:preview": "NITRO_PRESET=cloudflare-pages CLOUDFLARE_ENV=preview nuxt build && npx wrangler pages deploy dist --branch preview",
    "db:generate": "nuxt prepare && drizzle-kit generate --config=.nuxt/hub/db/drizzle.config.ts",
    "db:migrate": "npx wrangler d1 migrations apply kvr-db --local",
    "db:migrate:prod": "npx wrangler d1 migrations apply kvr-db --remote",
    "logs": "npx wrangler pages deployment tail --project-name kvr"
  },
  "dependencies": {
    "@fyit/crouton": "workspace:*",
    "@fyit/crouton-core": "workspace:*",
    "@fyit/crouton-devtools": "workspace:*",
    "@fyit/crouton-email": "workspace:*",
    "@fyit/crouton-i18n": "workspace:*",
    "@fyit/crouton-layout": "workspace:*",
    "@fyit/crouton-maps": "workspace:*",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "html2canvas-pro": "^2.0.2",
    "jspdf": "^4.2.1",
    "nuxt": "catalog:",
    "signature_pad": "^5.0.4",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@fyit/crouton-cli": "workspace:*",
    "drizzle-kit": "catalog:",
    "wrangler": "catalog:"
  }
}
